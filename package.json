{
  "name": "@skdev-ai/pi-gemini-cli-provider",
  "version": "0.1.0",
  "description": "Gemini LLM provider for Pi/GSD via A2A protocol with MCP tool bridge",
  "type": "module",
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "src/index.ts"
    ]
  },
  "keywords": [
    "pi-package",
    "pi",
    "gsd",
    "extension",
    "gemini-cli",
    "llm",
    "provider",
    "a2a",
    "mcp"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "skdev-ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skdev-ai/pi-gemini-cli-provider"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "scripts": {
    "test": "npx vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "dependencies": {
    "eventsource-parser": "3.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0",
    "@sinclair/typebox": "^0.34.48"
  }
}
